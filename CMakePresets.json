{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "LONEJSON_BUILD_TESTS": "ON",
        "LONEJSON_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "host",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "cacheVariables": {
        "LONEJSON_ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "fuzz",
      "inherits": "base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_C_COMPILER": "clang",
        "LONEJSON_BUILD_FUZZERS": "ON",
        "LONEJSON_BUILD_TESTS": "OFF",
        "LONEJSON_BUILD_EXAMPLES": "OFF"
      }
    },
    {
      "name": "stack-usage",
      "inherits": "debug",
      "cacheVariables": {
        "LONEJSON_ENABLE_STACK_USAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "host",
      "configurePreset": "host"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "fuzz",
      "configurePreset": "fuzz"
    },
    {
      "name": "format",
      "configurePreset": "debug",
      "targets": [
        "format"
      ]
    },
    {
      "name": "stack-usage-report",
      "configurePreset": "stack-usage",
      "targets": [
        "stack-usage-report"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "host",
      "configurePreset": "host",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
